# ===================================================================
# eCommerce Backend Environment Configuration Template (.env.example)
# ===================================================================

# ─── DATABASE SETTINGS (DEVELOPMENT / LOCAL) ────────────────────────
# JDBC URL to connect to the target MySQL database instance in development
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/your_dev_db
# Database login username
SPRING_DATASOURCE_USERNAME=your_dev_user
# Database login password
SPRING_DATASOURCE_PASSWORD=your_dev_password

# ─── DATABASE SETTINGS (PRODUCTION) ─────────────────────────────────
# JDBC URL to connect to the production MySQL database instance
DB_URL=jdbc:mysql://prod-db-host:3306/your_prod_db
# Production database login username
DB_USERNAME=your_prod_user
# Production database login password
DB_PASSWORD=your_prod_password
# Maximum connections in pool
DB_POOL_MAX=20
# Minimum idle connections in pool
DB_POOL_MIN=5

# ─── REDIS SETTINGS (DEVELOPMENT / LOCAL) ───────────────────────────
# Redis Cache host address in development
SPRING_REDIS_HOST=localhost
# Redis Cache port number in development
SPRING_REDIS_PORT=6379

# ─── REDIS SETTINGS (PRODUCTION) ────────────────────────────────────
# Redis Cache host address in production
REDIS_HOST=your_prod_redis_host
# Redis Cache port number in production
REDIS_PORT=6379

# ─── JAVAMAILSENDER SMTP SETTINGS ───────────────────────────────────
# SMTP server host domain name
SMTP_HOST=smtp.yourprovider.com
# SMTP server port (usually 587 for TLS, 465 for SSL)
SMTP_PORT=587
# SMTP username credentials
SMTP_USERNAME=your_smtp_username
# SMTP password credentials
SMTP_PASSWORD=your_smtp_password

# ─── JWT CRYPTOGRAPHIC CREDENTIALS ──────────────────────────────────
# Base64 encoded 256-bit secret key used to sign JWT signatures
JWT_SECRET=your_base64_encoded_256_bit_jwt_signing_key
# Access token validity duration in milliseconds (e.g. 1500000 = 25 mins)
JWT_EXPIRATION_MS=1500000
# Refresh token validity duration in milliseconds (e.g. 604800000 = 7 days)
JWT_REFRESH_EXPIRATION_MS=604800000

# ─── CORS SETTINGS ──────────────────────────────────────────────────
# Allowed origins for HTTP requests (comma-separated list)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ─── SYSTEM IDENTITY BOOTSTRAP SETTINGS (Sprint 16C) ────────────────
# Super Admin initialization username
SUPER_ADMIN_NAME=superadmin_user
# Super Admin initialization email login ID
SUPER_ADMIN_EMAIL=superadmin@yourdomain.com
# Super Admin temporary password (must meet complexity requirements)
SUPER_ADMIN_PASSWORD=your_complex_bootstrap_password
# Super Admin contact phone number (E.164 phone format)
SUPER_ADMIN_PHONE=+14155551234

# ─── MONITORING & SECURITY OVERRIDES ────────────────────────────────
# Set to 'true' to enable API rate limiting
APP_SECURITY_RATE_LIMIT_ENABLED=false
# Set to 'true' to expose separate Actuator liveness/readiness probes
MANAGEMENT_ENDPOINT_HEALTH_PROBES_ENABLED=false
