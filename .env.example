# Database Settings (Development MySQL)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/your_dev_db
SPRING_DATASOURCE_USERNAME=your_dev_user
SPRING_DATASOURCE_PASSWORD=your_dev_password

# Database Settings (Production MySQL)
DB_URL=jdbc:mysql://prod-db-host:3306/your_prod_db
DB_USERNAME=your_prod_user
DB_PASSWORD=your_prod_password
DB_POOL_MAX=20
DB_POOL_MIN=5

# Redis Cache Settings (Local & Dev)
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# Redis Cache Settings (Production)
REDIS_HOST=your_prod_redis_host
REDIS_PORT=6379

# JavaMailSender SMTP Settings (Gmail SMTP example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password

# JWT Cryptographic Credentials
JWT_SECRET=your_base64_encoded_256_bit_secret_key
JWT_EXPIRATION_MS=1500000
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS Configurations
CORS_ALLOWED_ORIGINS=https://your-domain.com
